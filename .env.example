# Core
NODE_ENV=development
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PORT=3000

# Payload
PAYLOAD_SECRET=your_payload_secret_min_32_characters
DATABASE_URI=postgresql://user:pass@host/db?sslmode=require
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Cloudflare R2
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your_r2_bucket_name
R2_PUBLIC_URL=https://your_custom_domain_or_pub_url.dev

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Resend
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=orders@yourdomain.com
RESEND_REPLY_TO=support@yourdomain.com
RESEND_WEBHOOK_SECRET=your_resend_webhook_secret

# Shippo (test mode token)
SHIPPO_API_TOKEN=shippo_test_your_token
SHIPPO_WEBHOOK_SECRET=your_shippo_webhook_secret

# Sentry
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=your_sentry_project_slug

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-your_measurement_id
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id

# Upstash (Phase 19)
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Meilisearch (Phase 16)
MEILISEARCH_HOST=your_meilisearch_host
MEILISEARCH_MASTER_KEY=your_meilisearch_master_key
NEXT_PUBLIC_MEILISEARCH_HOST=your_meilisearch_host
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=your_meilisearch_search_key

# Turnstile (Phase 19)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Cron
CRON_SECRET=your_cron_secret_min_32_characters

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
